# ===========================================
# VALT Website - Environment Configuration
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=valt_website

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=VALT Academy
SMTP_FROM_EMAIL=your-email@gmail.com

# Email Recipients
CONTACT_EMAIL=info@valtacademy.com
ENQUIRY_EMAIL=info@valtacademy.com

# WhatsApp API (future use)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER=

# Site Config
SITE_NAME=VALT Academy
SITE_URL=http://localhost:3000
